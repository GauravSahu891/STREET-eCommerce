# ─── SERVER ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/street_ecommerce
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/street_ecommerce

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ─── CLIENT ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173
